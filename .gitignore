# Build outputs
/build/
/dist/
*.o
*.exe
*.res
zmarkdown
# Windows resource build copies the ico next to the .rc; do not commit it.
/packaging/windows/icon.ico
tests/test_editing
tests/test_state
tests/test_markdown
tests/test_files
tests/test_history
/src/ui/assets/icon-*.png
/src/ui/assets/icon.ico
# icon-128.png is embedded into the binary at compile time, so keep a copy in
# git; a plain `nim cpp` should build without running the icon script first.
!/src/ui/assets/icon-128.png

# Microsoft WebView2 SDK headers are fetched at build time (Windows only) by
# scripts/fetch-webview2.ps1, never committed. See THIRD-PARTY-LICENSES.md.
/src/vendor/webview/libs/webview2/

# Nim caches
nimcache/
.nimcache/
/nimble.develop
/nimble.paths

# Editor/OS noise
*~
.DS_Store
